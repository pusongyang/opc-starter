# ===========================================
# OPC-Starter 环境变量模板
# 唯一权威模板：复制为 .env.local 后再填写真实值
# ===========================================

# ---- 前端公开变量（真实 Supabase 模式必填）----
# 从 Supabase Dashboard -> Settings -> API 获取
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ---- 本地开关（按需启用）----
# 设为 true 时走 MSW Mock，无需真实 Supabase；生产部署请保持 false 或留空
# VITE_ENABLE_MSW=false

# 仅在本地排查时需要；未设置时应用使用默认级别
# VITE_LOG_LEVEL=info

# ---- 服务端 Secret（仅说明，不要写进 .env.local）----
# 以下变量由 Supabase Edge Functions Secrets 提供：
# ALIYUN_BAILIAN_API_KEY=sk-xxx
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=service-role-key
